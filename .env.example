# Optional absolute site URL for metadata + JSON-LD (defaults in layout).
NEXT_PUBLIC_SITE_URL=https://www.taqueriaibarrakc.com

# Published Google Sheet CSV URL (server fetch). Prefer MENU_CSV_URL over NEXT_PUBLIC_*.
MENU_CSV_URL=
NEXT_PUBLIC_MENU_CSV_URL=

# Published Google Sheet CSV for locations (food truck + restaurant rows). Prefer LOCATIONS_CSV_URL.
LOCATIONS_CSV_URL=
NEXT_PUBLIC_LOCATIONS_CSV_URL=

# Optional: published CSV for tab "Truck pin" — overrides address/lat/lng/placeId for the primary food truck before geocoding. Prefer TRUCK_PIN_CSV_URL (server).
TRUCK_PIN_CSV_URL=
NEXT_PUBLIC_TRUCK_PIN_CSV_URL=

# Browser/public Google Maps key. Restrict by HTTP referrer.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: server-side Geocoding API only (not required if you use website-restricted public key + client geocoding). Restrict by IP when set.
GOOGLE_MAPS_SERVER_KEY=
# Alternate name accepted for the same server Geocoding key.
GOOGLE_MAPS_API_KEY=

# Clover (sandbox). Use production keys when going live.
NEXT_PUBLIC_CLOVER_PUBLIC_TOKEN_SANDBOX=
NEXT_PUBLIC_CLOVER_MERCHANT_ID_SANDBOX=
# sandbox | production
NEXT_PUBLIC_CLOVER_ENV=sandbox
